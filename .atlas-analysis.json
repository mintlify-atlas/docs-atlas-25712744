  "keyFeatures": [
    "Declarative component-based UI with reactive state management",
    "Cross-platform native rendering powered by Skia graphics engine",
    "Rich set of built-in components (buttons, inputs, tables, calendars, color pickers)",
    "Smooth animations with easing functions and transitions",
    "Routing and navigation system for multi-page applications",
    "Advanced text editing with cursor management and selection",
    "Code editor with syntax highlighting via tree-sitter",
    "Terminal emulation with PTY support",
    "WebView integration for embedding web content",
    "Internationalization (i18n) with Fluent localization",
    "Global state management via radio channels",
    "Headless testing framework for UI components",
    "Plotting and data visualization with Plotters",
    "Material Design components and styling",
    "Icon library support (Lucide)",
    "Accessibility support with screen readers and focus management",
    "Developer tools for component tree inspection"
  ],
  "publicApiSurface": [
    "launch() - Start application with window configuration",
    "rect() - Create rectangle element",
    "label() - Create text label element",
    "paragraph() - Create multi-line text element",
    "svg() - Render SVG graphics",
    "use_state() - Reactive state hook",
    "use_effect() - Side effect hook",
    "use_memo() - Memoized value hook",
    "use_animation() - Animation control hook",
    "use_editable() - Text editing hook",
    "use_focus() - Focus management hook",
    "use_radio() - Global state subscription",
    "use_i18n() - Internationalization hook",
    "Button - Button component",
    "Input - Text input component",
    "Checkbox - Checkbox component",
    "Switch - Toggle switch component",
    "Slider - Range slider component",
    "VirtualScrollView - Virtualized scrolling component",
    "Table - Data table component",
    "Calendar - Date picker component",
    "ColorPicker - Color selection component",
    "ImageViewer - Image display component",
    "GifViewer - Animated GIF component",
    "CodeEditor - Code editing component",
    "Terminal - Terminal emulator component",
    "WebView - Web content component",
    "router() - Router configuration",
    "Link - Navigation link component",
    "TestingRunner - Headless testing runner"
  ]
}
